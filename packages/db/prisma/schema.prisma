generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

enum TaskStatus {
  pending
  scheduled
  completed
  archived
  backlog
}

enum HabitPeriod {
  week
}

enum HabitStatus {
  active
  paused
}

model User {
  id                 String   @id @default(uuid())
  email              String   @unique
  googleId           String?  @unique
  googleRefreshToken       String?
  autoScheduledCalendarId  String?
  createdAt                DateTime @default(now()) @db.Timestamptz
  updatedAt          DateTime @updatedAt @db.Timestamptz

  settings            Settings?
  calendarEvents      CalendarEvent[]
  tasks               Task[]
  habits              Habit[]
  categories          Category[]
  scheduledBlocks     ScheduledBlock[]
  calendarSyncStates  CalendarSyncState[]
}

model Settings {
  id                String   @id @default(uuid())
  userId            String   @unique
  timezone          String
  workingHours      Json
  horizonDays       Int      @default(14)
  defaultMinChunkMs Int
  defaultMaxChunkMs Int
  meetingBufferMs   Int      @default(0)
  taskBufferMs      Int      @default(0)
  requireStartToTrack Boolean @default(false)
  createdAt         DateTime @default(now()) @db.Timestamptz
  updatedAt         DateTime @updatedAt @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CalendarEvent {
  id               String   @id @default(uuid())
  userId           String
  googleCalendarId String?
  googleEventId    String?
  title            String
  startsAt         DateTime @db.Timestamptz
  endsAt           DateTime @db.Timestamptz
  createdAt        DateTime @default(now()) @db.Timestamptz
  updatedAt        DateTime @updatedAt @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, googleCalendarId, googleEventId])
}

model Task {
  id           String     @id @default(uuid())
  userId       String
  title        String
  priority     Int
  sortOrder    Float    @default(0)
  durationMs   Int
  dueBy        DateTime   @db.Timestamptz
  notBefore    DateTime?  @db.Timestamptz
  minChunkMs   Int
  maxChunkMs   Int
  categoryId   String?
  status       TaskStatus @default(pending)
  completedAt  DateTime?  @db.Timestamptz
  timeLoggedMs Int        @default(0)
  createdAt    DateTime   @default(now()) @db.Timestamptz
  updatedAt    DateTime   @updatedAt @db.Timestamptz

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  category        Category?        @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  scheduledBlocks ScheduledBlock[]
  subtasks        Subtask[]
}

model Subtask {
  id        String   @id @default(uuid())
  taskId    String
  title     String
  done      Boolean  @default(false)
  sortOrder Float    @default(0)
  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model Category {
  id        String   @id @default(uuid())
  userId    String
  name      String
  windows   Json?
  color     String?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks Task[]

  @@unique([userId, name])
}

model Habit {
  id                   String      @id @default(uuid())
  userId               String
  title                String
  priority             Int
  chunkMs              Int
  perPeriod            Int
  periodType           HabitPeriod @default(week)
  preferredStartMinute Int?
  preferredEndMinute   Int?
  eligibleDays         Int[]
  status               HabitStatus @default(active)
  createdAt            DateTime    @default(now()) @db.Timestamptz
  updatedAt            DateTime    @updatedAt @db.Timestamptz

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  scheduledBlocks ScheduledBlock[]
}

model ScheduledBlock {
  id               String   @id @default(uuid())
  userId           String
  taskId           String?
  habitId          String?
  title            String
  startsAt         DateTime @db.Timestamptz
  endsAt           DateTime @db.Timestamptz
  pinned           Boolean  @default(false)
  googleEventId    String?
  googleCalendarId String?
  engineKey        String?
  startedAt        DateTime? @db.Timestamptz
  createdAt        DateTime @default(now()) @db.Timestamptz
  updatedAt        DateTime @updatedAt @db.Timestamptz

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  task  Task?  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  habit Habit? @relation(fields: [habitId], references: [id], onDelete: Cascade)

  @@unique([userId, engineKey])
}

model CalendarSyncState {
  id               String    @id @default(uuid())
  userId           String
  googleCalendarId String
  syncToken        String?
  lastSyncedAt     DateTime? @db.Timestamptz
  createdAt        DateTime  @default(now()) @db.Timestamptz
  updatedAt        DateTime  @updatedAt @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, googleCalendarId])
}
